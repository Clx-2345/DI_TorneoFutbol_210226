<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="Informe_Equipos_Jugadores" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    
    <parameter name="EQUIPO_FILTRO" class="java.lang.String" isForPrompting="false">
        <defaultValueExpression><![CDATA[""]]></defaultValueExpression>
    </parameter>
    
    <queryString>
        <![CDATA[SELECT 
            e.id as equipo_id,
            e.nombre as equipo_nombre,
            e.curso as equipo_curso,
            e.color_camiseta,
            p.id as jugador_id,
            p.nombre as jugador_nombre,
            p.posicion,
            COALESCE(p.goles, 0) as goles,
            COALESCE(p.t_amarillas, 0) as t_amarillas,
            COALESCE(p.t_rojas, 0) as t_rojas
        FROM equipos e
        LEFT JOIN participantes p ON e.id = p.equipo_id AND p.es_jugador = 1
        WHERE CAST($P{EQUIPO_FILTRO} AS TEXT) = '' OR e.nombre LIKE '%' || CAST($P{EQUIPO_FILTRO} AS TEXT) || '%'
        ORDER BY e.nombre, p.nombre]]>
    </queryString>
    
    <field name="equipo_id" class="java.lang.Integer"/>
    <field name="equipo_nombre" class="java.lang.String"/>
    <field name="equipo_curso" class="java.lang.String"/>
    <field name="color_camiseta" class="java.lang.String"/>
    <field name="jugador_id" class="java.lang.Integer"/>
    <field name="jugador_nombre" class="java.lang.String"/>
    <field name="posicion" class="java.lang.String"/>
    <field name="goles" class="java.lang.Integer"/>
    <field name="t_amarillas" class="java.lang.Integer"/>
    <field name="t_rojas" class="java.lang.Integer"/>
    
    <variable name="total_goles_equipo" class="java.lang.Integer" resetType="Group" resetGroup="equipo_group" calculation="Sum">
        <variableExpression><![CDATA[$F{goles}]]></variableExpression>
    </variable>
    
    <variable name="total_amarillas_equipo" class="java.lang.Integer" resetType="Group" resetGroup="equipo_group" calculation="Sum">
        <variableExpression><![CDATA[$F{t_amarillas}]]></variableExpression>
    </variable>
    
    <variable name="total_rojas_equipo" class="java.lang.Integer" resetType="Group" resetGroup="equipo_group" calculation="Sum">
        <variableExpression><![CDATA[$F{t_rojas}]]></variableExpression>
    </variable>
    
    <variable name="count_jugadores" class="java.lang.Integer" resetType="Group" resetGroup="equipo_group" calculation="Count">
        <variableExpression><![CDATA[$F{jugador_id}]]></variableExpression>
    </variable>
    
    <group name="equipo_group">
        <groupExpression><![CDATA[$F{equipo_id}]]></groupExpression>
        <groupHeader>
            <band height="60">
                <textField>
                    <reportElement x="0" y="10" width="400" height="25" forecolor="#0066CC"/>
                    <textElement>
                        <font size="16" isBold="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA[$F{equipo_nombre}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="400" y="10" width="155" height="25"/>
                    <textElement textAlignment="Right">
                        <font size="12"/>
                    </textElement>
                    <textFieldExpression><![CDATA["Curso: " + $F{equipo_curso}]]></textFieldExpression>
                </textField>
                <staticText>
                    <reportElement x="0" y="40" width="200" height="20" mode="Opaque" backcolor="#CCCCCC"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Center"><font isBold="true"/></textElement>
                    <text><![CDATA[Jugador]]></text>
                </staticText>
                <staticText>
                    <reportElement x="200" y="40" width="100" height="20" mode="Opaque" backcolor="#CCCCCC"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Center"><font isBold="true"/></textElement>
                    <text><![CDATA[Posición]]></text>
                </staticText>
                <staticText>
                    <reportElement x="300" y="40" width="85" height="20" mode="Opaque" backcolor="#CCCCCC"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Center"><font isBold="true"/></textElement>
                    <text><![CDATA[Goles]]></text>
                </staticText>
                <staticText>
                    <reportElement x="385" y="40" width="85" height="20" mode="Opaque" backcolor="#CCCCCC"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Center"><font isBold="true"/></textElement>
                    <text><![CDATA[T. Amarillas]]></text>
                </staticText>
                <staticText>
                    <reportElement x="470" y="40" width="85" height="20" mode="Opaque" backcolor="#CCCCCC"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Center"><font isBold="true"/></textElement>
                    <text><![CDATA[T. Rojas]]></text>
                </staticText>
            </band>
        </groupHeader>
        <groupFooter>
            <band height="50">
                <staticText>
                    <reportElement x="0" y="5" width="200" height="20" mode="Opaque" backcolor="#EEEEEE"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Right"><font isBold="true"/></textElement>
                    <text><![CDATA[TOTALES:  ]]></text>
                </staticText>
                <textField>
                    <reportElement x="300" y="5" width="85" height="20" mode="Opaque" backcolor="#EEEEEE"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Center"><font isBold="true"/></textElement>
                    <textFieldExpression><![CDATA[$V{total_goles_equipo}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="385" y="5" width="85" height="20" mode="Opaque" backcolor="#EEEEEE"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Center"><font isBold="true"/></textElement>
                    <textFieldExpression><![CDATA[$V{total_amarillas_equipo}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="470" y="5" width="85" height="20" mode="Opaque" backcolor="#EEEEEE"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Center"><font isBold="true"/></textElement>
                    <textFieldExpression><![CDATA[$V{total_rojas_equipo}]]></textFieldExpression>
                </textField>
                <textField>
                    <reportElement x="200" y="5" width="100" height="20" mode="Opaque" backcolor="#EEEEEE"/>
                    <box><pen lineWidth="0.5"/></box>
                    <textElement textAlignment="Center"><font isBold="true"/></textElement>
                    <textFieldExpression><![CDATA["Jugadores: " + $V{count_jugadores}]]></textFieldExpression>
                </textField>
            </band>
        </groupFooter>
    </group>
    
    <title>
        <band height="70">
            <staticText>
                <reportElement x="0" y="0" width="555" height="40"/>
                <textElement textAlignment="Center">
                    <font size="22" isBold="true"/>
                </textElement>
                <text><![CDATA[TORNEO DE FÚTBOL]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="40" width="555" height="25"/>
                <textElement textAlignment="Center">
                    <font size="14"/>
                </textElement>
                <text><![CDATA[Informe de Equipos y Jugadores]]></text>
            </staticText>
        </band>
    </title>
    
    <pageHeader>
        <band height="20">
            <textField pattern="dd/MM/yyyy HH:mm">
                <reportElement x="400" y="0" width="155" height="15"/>
                <textElement textAlignment="Right">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
        </band>
    </pageHeader>
    
    <detail>
        <band height="20">
            <textField isBlankWhenNull="true">
                <reportElement x="0" y="0" width="200" height="20"/>
                <box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box>
                <textElement><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{jugador_nombre}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="200" y="0" width="100" height="20"/>
                <box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box>
                <textElement textAlignment="Center"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{posicion}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="300" y="0" width="85" height="20"/>
                <box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box>
                <textElement textAlignment="Center"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{goles}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="385" y="0" width="85" height="20"/>
                <box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box>
                <textElement textAlignment="Center"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{t_amarillas}]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="470" y="0" width="85" height="20"/>
                <box><pen lineWidth="0.5" lineColor="#CCCCCC"/></box>
                <textElement textAlignment="Center"><font size="10"/></textElement>
                <textFieldExpression><![CDATA[$F{t_rojas}]]></textFieldExpression>
            </textField>
        </band>
    </detail>
    
    <pageFooter>
        <band height="20">
            <textField>
                <reportElement x="200" y="0" width="155" height="15"/>
                <textElement textAlignment="Center">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>
    
</jasperReport>
