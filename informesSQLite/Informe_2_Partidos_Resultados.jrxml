<?xml version="1.0" encoding="UTF-8"?>
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="Informe_Partidos_Resultados" pageWidth="595" pageHeight="842" columnWidth="555" leftMargin="20" rightMargin="20" topMargin="20" bottomMargin="20">
    
    <parameter name="ELIMINATORIA_FILTRO" class="java.lang.String" isForPrompting="false">
        <defaultValueExpression><![CDATA[""]]></defaultValueExpression>
    </parameter>
    
    <queryString>
        <![CDATA[SELECT 
            p.id,
            p.fecha,
            p.hora,
            p.eliminatoria,
            COALESCE(p.lugar, 'Por definir') as lugar,
            COALESCE(p.jugado, 0) as jugado,
            COALESCE(p.goles_local, 0) as goles_local,
            COALESCE(p.goles_visitante, 0) as goles_visitante,
            el.nombre as equipo_local,
            ev.nombre as equipo_visitante,
            arb.nombre as arbitro
        FROM partidos p
        LEFT JOIN equipos el ON p.equipo_local_id = el.id
        LEFT JOIN equipos ev ON p.equipo_visitante_id = ev.id
        LEFT JOIN participantes arb ON p.arbitro_id = arb.id
        WHERE CAST($P{ELIMINATORIA_FILTRO} AS TEXT) = '' OR p.eliminatoria = CAST($P{ELIMINATORIA_FILTRO} AS TEXT)
        ORDER BY p.fecha, p.hora, p.eliminatoria]]>
    </queryString>
    
    <field name="id" class="java.lang.Integer"/>
    <field name="fecha" class="java.lang.String"/>
    <field name="hora" class="java.lang.String"/>
    <field name="eliminatoria" class="java.lang.String"/>
    <field name="lugar" class="java.lang.String"/>
    <field name="jugado" class="java.lang.Integer"/>
    <field name="goles_local" class="java.lang.Integer"/>
    <field name="goles_visitante" class="java.lang.Integer"/>
    <field name="equipo_local" class="java.lang.String"/>
    <field name="equipo_visitante" class="java.lang.String"/>
    <field name="arbitro" class="java.lang.String"/>
    
    <variable name="partidos_jugados" class="java.lang.Integer" calculation="Sum">
        <variableExpression><![CDATA[$F{jugado}]]></variableExpression>
    </variable>
    
    <variable name="total_goles" class="java.lang.Integer" calculation="Sum">
        <variableExpression><![CDATA[$F{goles_local} + $F{goles_visitante}]]></variableExpression>
    </variable>
    
    <group name="eliminatoria_group">
        <groupExpression><![CDATA[$F{eliminatoria}]]></groupExpression>
        <groupHeader>
            <band height="40">
                <textField>
                    <reportElement x="0" y="10" width="555" height="25" mode="Opaque" backcolor="#0066CC" forecolor="#FFFFFF"/>
                    <box><pen lineWidth="1.0"/></box>
                    <textElement textAlignment="Center" verticalAlignment="Middle">
                        <font size="14" isBold="true"/>
                    </textElement>
                    <textFieldExpression><![CDATA[$F{eliminatoria}.toUpperCase()]]></textFieldExpression>
                </textField>
            </band>
        </groupHeader>
    </group>
    
    <title>
        <band height="70">
            <staticText>
                <reportElement x="0" y="0" width="555" height="40"/>
                <textElement textAlignment="Center">
                    <font size="22" isBold="true"/>
                </textElement>
                <text><![CDATA[TORNEO DE FÚTBOL]]></text>
            </staticText>
            <staticText>
                <reportElement x="0" y="40" width="555" height="25"/>
                <textElement textAlignment="Center">
                    <font size="14"/>
                </textElement>
                <text><![CDATA[Informe de Partidos y Resultados]]></text>
            </staticText>
        </band>
    </title>
    
    <pageHeader>
        <band height="20">
            <textField pattern="dd/MM/yyyy HH:mm">
                <reportElement x="400" y="0" width="155" height="15"/>
                <textElement textAlignment="Right">
                    <font size="8"/>
                </textElement>
                <textFieldExpression><![CDATA[new java.util.Date()]]></textFieldExpression>
            </textField>
        </band>
    </pageHeader>
    
    <detail>
        <band height="80">
            <rectangle>
                <reportElement x="0" y="5" width="555" height="70" mode="Transparent">
                    <printWhenExpression><![CDATA[$F{jugado} == 0]]></printWhenExpression>
                </reportElement>
                <graphicElement>
                    <pen lineWidth="1.0" lineColor="#FFAA00"/>
                </graphicElement>
            </rectangle>
            <rectangle>
                <reportElement x="0" y="5" width="555" height="70" mode="Transparent">
                    <printWhenExpression><![CDATA[$F{jugado} == 1]]></printWhenExpression>
                </reportElement>
                <graphicElement>
                    <pen lineWidth="1.0" lineColor="#00AA00"/>
                </graphicElement>
            </rectangle>
            
            <!-- Fecha y Hora -->
            <textField>
                <reportElement x="10" y="10" width="100" height="15"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA["📅 " + $F{fecha}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="120" y="10" width="100" height="15"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA["🕒 " + $F{hora}]]></textFieldExpression>
            </textField>
            
            <!-- Estado -->
            <staticText>
                <reportElement x="430" y="10" width="120" height="15" forecolor="#00AA00">
                    <printWhenExpression><![CDATA[$F{jugado} == 1]]></printWhenExpression>
                </reportElement>
                <textElement textAlignment="Right"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[✓ JUGADO]]></text>
            </staticText>
            <staticText>
                <reportElement x="430" y="10" width="120" height="15" forecolor="#FFAA00">
                    <printWhenExpression><![CDATA[$F{jugado} == 0]]></printWhenExpression>
                </reportElement>
                <textElement textAlignment="Right"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[⏳ PENDIENTE]]></text>
            </staticText>
            
            <!-- Equipos -->
            <textField>
                <reportElement x="10" y="30" width="200" height="20"/>
                <textElement><font size="12" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{equipo_local}]]></textFieldExpression>
            </textField>
            <staticText>
                <reportElement x="220" y="30" width="40" height="20"/>
                <textElement textAlignment="Center"><font size="12" isBold="true"/></textElement>
                <text><![CDATA[VS]]></text>
            </staticText>
            <textField>
                <reportElement x="270" y="30" width="200" height="20"/>
                <textElement textAlignment="Right"><font size="12" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{equipo_visitante}]]></textFieldExpression>
            </textField>
            
            <!-- Resultado -->
            <textField>
                <reportElement x="180" y="50" width="195" height="20">
                    <printWhenExpression><![CDATA[$F{jugado} == 1]]></printWhenExpression>
                </reportElement>
                <textElement textAlignment="Center">
                    <font size="14" isBold="true" isItalic="true"/>
                </textElement>
                <textFieldExpression><![CDATA["Resultado: " + $F{goles_local} + " - " + $F{goles_visitante}]]></textFieldExpression>
            </textField>
            
            <!-- Árbitro y Lugar -->
            <textField isBlankWhenNull="true">
                <reportElement x="10" y="55" width="200" height="15"/>
                <textElement><font size="8"/></textElement>
                <textFieldExpression><![CDATA["Árbitro: " + ($F{arbitro} != null ? $F{arbitro} : "Sin asignar")]]></textFieldExpression>
            </textField>
            <textField isBlankWhenNull="true">
                <reportElement x="350" y="55" width="200" height="15"/>
                <textElement textAlignment="Right"><font size="8"/></textElement>
                <textFieldExpression><![CDATA["Lugar: " + ($F{lugar} != null ? $F{lugar} : "Por definir")]]></textFieldExpression>
            </textField>
        </band>
    </detail>
    
    <pageFooter>
        <band height="20">
            <textField>
                <reportElement x="200" y="0" width="155" height="15"/>
                <textElement textAlignment="Center">
                    <font size="9"/>
                </textElement>
                <textFieldExpression><![CDATA["Página " + $V{PAGE_NUMBER}]]></textFieldExpression>
            </textField>
        </band>
    </pageFooter>
    
    <summary>
        <band height="80">
            <staticText>
                <reportElement x="0" y="10" width="555" height="25"/>
                <textElement textAlignment="Center">
                    <font size="14" isBold="true"/>
                </textElement>
                <text><![CDATA[RESUMEN DEL TORNEO]]></text>
            </staticText>
            <textField>
                <reportElement x="100" y="45" width="150" height="20"/>
                <textElement><font size="11"/></textElement>
                <textFieldExpression><![CDATA["Partidos jugados: " + $V{partidos_jugados}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="300" y="45" width="150" height="20"/>
                <textElement><font size="11"/></textElement>
                <textFieldExpression><![CDATA["Total goles: " + $V{total_goles}]]></textFieldExpression>
            </textField>
        </band>
    </summary>
    
</jasperReport>
